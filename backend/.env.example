# e-conomic API credentials
# Get these from: https://secure.e-conomic.com/settings/developer
ECONOMIC_APP_SECRET_TOKEN=your_app_secret_token_here
ECONOMIC_AGREEMENT_GRANT_TOKEN=your_agreement_grant_token_here

# The dimension value that marks invoices for 1-to-1 re-invoicing
# This must match exactly how it appears in e-conomic
REINVOICE_DIMENSION_VALUE=to be re-invoiced 1 to 1

# Server port
PORT=3001
